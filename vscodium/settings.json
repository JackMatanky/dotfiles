{
  // --------------------------------------------
  // Global Settings
  // --------------------------------------------
  "extensions.additionalExtensionGallery": [
    {
      "serviceUrl": "https://marketplace.visualstudio.com/_apis/public/gallery",
      "itemUrl": "https://marketplace.visualstudio.com/items",
      "controlUrl": "",
      "cacheUrl": "https://vscode.blob.core.windows.net/gallery/index",
      "resourceUrlTemplate": "https://{publisher}.gallery.vsassets.io/_apis/public/gallery/publisher/{publisher}/extension/{extension}/{version}/assetbyname/{assetName}"
    }
  ],

  "editor.fontFamily": "FiraCode Nerd Font Mono",
  "editor.fontSize": 15,
  "editor.fontLigatures": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.foldingMaximumRegions": 10000,
  "editor.wordWrap": "on",
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "diffEditor.codeLens": true,

  "window.restoreWindows": "preserve",
  "window.newWindowProfile": "Default",

  "files.associations": {
    "*.pgsql": "postgres",
    "*.html": "html",
    "brew*": "ruby",
    "uv.lock": "toml",
    "snippets/*.json": "jsonc"
  },

  "security.workspace.trust.untrustedFiles": "open",

  // --------------------------------------------
  //SECTION - Appearance and Theme
  // --------------------------------------------
  //SEGMENT - Theme
  "workbench.preferredDarkColorTheme": "Catppuccin Macchiato",
  "workbench.colorTheme": "Catppuccin Macchiato",
  "catppuccin.accentColor": "blue",
  //!SEGMENT

  //SEGMENT - Icons
  // Grey - #90a4ae; Light Beige - #f7d88c; Darker Beige - #e6c04c
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.activeIconPack": "none",
  "material-icon-theme.files.color": "#90a4ae",
  "material-icon-theme.folders.color": "#ddbb77",
  "material-icon-theme.folders.theme": "specific",
  //!SEGMENT

  "workbench.settings.applyToAllProfiles": [
    "editor.defaultFormatter",
    "workbench.commandPalette.experimental.suggestCommands",
    "workbench.externalBrowser",
    "python.analysis.inlayHints.variableTypes",
    "python.analysis.inlayHints.functionReturnTypes",
    "python.analysis.inlayHints.callArgumentNames",
    "notebook.defaultFormatter",
    "SQL-Formatter-VSCode.dataTypeCase",
    "SQL-Formatter-VSCode.denseOperators",
    "SQL-Formatter-VSCode.expressionWidth",
    "SQL-Formatter-VSCode.functionCase",
    "html.format.extraLiners",
    "vsicons.presets.hideExplorerArrows",
    "markdown.preview.lineHeight",
    "terminal.integrated.defaultProfile.osx",
    "terminal.integrated.defaultProfile.windows"
  ],

  "workbench.settings.openDefaultKeybindings": true,
  "workbench.externalBrowser": "edge",
  "workbench.experimental.enableNewProfilesUI": true,
  "workbench.commandPalette.experimental.suggestCommands": true,
  //!SECTION

  // --------------------------------------------
  //SECTION - Shell & Terminal
  // --------------------------------------------
  //SEGMENT - Nushell
  "nushellLanguageServer.includeDirs": [
    "/Users/jack/dotfiles/nushell",
    "/Users/jack/dotfiles/nushell/aliases",
    "/Users/jack/dotfiles/nushell/completions",
    "/Users/jack/dotfiles/nushell/themes"
  ],
  "nushellLanguageServer.nushellExecutablePath": "nu",
  //!SEGMENT

  "terminal.external.osxExec": "Ghostty.app",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.windows": "Nushell",
  "terminal.integrated.defaultProfile.osx": "Nushell",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.enableImages": true,
  "terminal.integrated.sendKeybindingsToShell": true,
  //!SECTION

  // --------------------------------------------
  //SECTION - NeoVim
  // --------------------------------------------
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
  //"vscode-neovim.neovimExecutablePaths.windows": "C:\\path\\to\\nvim.exe"
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  //!SECTION

  // --------------------------------------------
  // Spellcheck
  // --------------------------------------------
  "cSpell.enabled": true,
  "spellright.addToSystemDictionary": true,
  "spellright.notificationClass": "warning",
  "spellright.configurationScope": "user",
  "spellright.language": ["en"],
  "spellright.documentTypes": ["markdown", "latex"],

  // --------------------------------------------
  // Formatting Settings
  // --------------------------------------------
  "prettier.endOfLine": "lf",
  "prettier.htmlWhitespaceSensitivity": "css",
  "prettier.semi": true,
  "prettier.singleAttributePerLine": true,
  "prettier.singleQuote": true,
  "prettier.bracketSameLine": true,

  "less.format.enable": false,
  "formatContextMenu.closeAfterSave": true,

  // --------------------------------------------
  // Comment Extensions
  // --------------------------------------------
  "commentAnchors.tags.separators": [" - ", ": ", " "],
  "commentAnchors.tagHighlights.enabled": true,
  "commentAnchors.tags.displayHierarchyInWorkspace": true,
  "commentAnchors.tags.displayInGutter": true,
  "commentAnchors.tags.displayLineNumber": true,
  "commentAnchors.tags.endTag": "!",
  "commentAnchors.tags.matchPrefix": [
    "<!--",
    "//",
    "/*",
    "/**",
    "*",
    "#",
    "--"
  ],
  "commentAnchors.tags.list": [
    {
      "tag": "ANCHOR",
      "iconColor": "purple",
      "highlightColor": "#A8C023",
      "scope": "file"
    },
    {
      "tag": "SECTION",
      "iconColor": "blurple",
      "highlightColor": "#896afc",
      "styleMode": "full",
      "scope": "workspace",
      "behavior": "region"
    },
    {
      "tag": "SEGMENT",
      "iconColor": "blue",
      "highlightColor": "#3ea8ff",
      "styleMode": "full",
      "scope": "file",
      "behavior": "region"
    },
    {
      "tag": "REVIEW",
      "iconColor": "orange",
      "highlightColor": "#FFB300",
      "scope": "workspace"
    },
    {
      "tag": "TODO",
      "iconColor": "yellow",
      "highlightColor": "#3ea8ff",
      "scope": "workspace"
    },
    {
      "tag": "FIXME",
      "iconColor": "red",
      "highlightColor": "#F44336",
      "styleMode": "full",
      "scope": "workspace"
    },
    {
      "tag": "STUB",
      "iconColor": "teal",
      "highlightColor": "#BA68C8",
      "scope": "file"
    },
    // Information Tags
    {
      "tag": "NOTE",
      "iconColor": "green",
      "highlightColor": "#64DD17",
      "scope": "file"
    },
    {
      "tag": "LINK",
      "iconColor": "emerald",
      "highlightColor": "#2ecc71",
      "scope": "workspace",
      "behavior": "link"
    },
    {
      "tag": "SOURCE",
      "iconColor": "yellow",
      "highlightColor": "#2ecc71",
      "scope": "workspace",
      "behavior": "link"
    }
  ],

  "better-comments.multilineComments": true,
  "better-comments.highlightPlainText": false,
  "better-comments.tags": [
    {
      "tag": "<>", // Section
      "color": "#F1FA8C",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": true
    },
    {
      "tag": "*", // Important
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "!", // Warning
      "color": "#FF5555",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "?", // Question
      "color": "#b855ff",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    }
  ],

  // --------------------------------------------
  // Extensions
  // --------------------------------------------
  "liveServer.settings.donotShowInfoMsg": true,
  "latex-workshop.view.pdf.viewer": "browser",
  "redhat.telemetry.enabled": false,
  "github.copilot.nextEditSuggestions.enabled": true,

  // --------------------------------------------
  // Language Configurations
  // --------------------------------------------

  //SECTION - Python
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.detectIndentation": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 80,
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "python.defaultInterpreterPath": "/Users/jack/.pyenv/shims/python",
  "python.analysis.autoFormatStrings": true,
  "python.analysis.inlayHints.callArgumentNames": "partial",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.REPL.sendToNativeREPL": true,
  "python.terminal.activateEnvironment": true,
  "python.terminal.shellIntegration.enabled": true,
  "python.venvPath": ".venv",
  "python.venvFolders": [".pyenv"],

  //SEGMENT - Ruff
  "ruff.path": ["/opt/homebrew/bin/ruff"],
  "ruff.lineLength": 80,
  "ruff.organizeImports": true,
  //!SEGMENT

  //SEGMENT - Pylyzer
  "pylyzer.diagnostics": false,
  //!SEGMENT

  //SEGMENT - BasedPyright
  "basedpyright.analysis.inlayHints.genericTypes": true,
  "basedpyright.analysis.diagnosticMode": "workspace",
  "basedpyright.analysis.autoSearchPaths": true,
  "basedpyright.analysis.typeCheckingMode": "basic",
  "basedpyright.analysis.diagnosticSeverityOverrides": {
    // ─── Critical Issues ───
    "reportMissingImports": "error",
    // ─── Optional / Informational ───
    "reportMissingTypeStubs": "hint",
    "reportUnusedImport": "hint",
    "reportUnusedClass": "hint",
    "reportUnusedFunction": "hint",
    "reportUnusedVariable": "hint",
    "reportDuplicateImport": "hint",
    // ─── Silenced Warnings (Noisy or Covered by Ruff) ---
    "reportImportCycles": "none",
    "reportRedundantKeywordArg": "none",
    "reportRedundantCast": "none",
    "reportUnnecessaryTypeIgnoreComment": "none",
    "reportUnknownVariableType": "none",
    "reportUnknownMemberType": "none",
    "reportUnknownArgumentType": "none",
    "reportUnknownLambdaType": "none",
    "reportCallInDefaultInitializer": "none",
    "reportImplicitOverride": "none",
    "reportExplicitAny": "none"
  },
  //!SEGMENT - Pyright

  //SEGMENT - Marimo
  "marimo.pythonPath": "${workspaceFolder}/.venv/bin/python",
  "marimo.marimoPath": "uv run marimo",
  "marimo.debug": true,
  "marimo.https": true,
  //!SEGMENT
  //!SECTION

