{
  "version": "0.2",
  "language": "en,he",
  "ignorePaths": [],
  "dictionaryDefinitions": [
    {
      "name": "hebrew",
      "path": "/opt/homebrew/lib/node_modules/@cspell/dict-he/hebrew-words.txt",
      "description": "Hebrew words from cspell-dict-he",
      "addWords": false
    }
  ],
  "dictionaries": ["hebrew"],
  "customDictionaries": {
    "user_dictionary_eng": {
      "name": "general_dictionary",
      "path": "~/.config/cspell/dictionaries/user_dictionary_eng.txt",
      "addWords": true,
      "scope": "user"
    },
    "user_dictionary_python": {
      "name": "python_dictionary",
      "path": "~/.config/cspell/dictionaries/user_dictionary_python.txt",
      "addWords": true,
      "scope": "user"
    }
  },
  "words": [],
  "ignoreWords": ["PREMADE", "canonizer"],
  "import": [],
  "languageSettings": [
    { "languageId": "python", "dictionaries": ["python"] },
    { "languageId": "javascript", "dictionaries": ["typescript", "node"] }
  ]
}
